{
  "name": "tinypath-js",
  "version": "1.0.0",
  "description": "JavaScript/TypeScript implementation of TinyPath, a minimal JSON path expression language for IoT scenarios",
  "keywords": [
    "tinypath",
    "jsonpath",
    "iot",
    "mqtt"
  ],
  "homepage": "https://github.com/dcsuibian/tinypath#readme",
  "bugs": {
    "url": "https://github.com/dcsuibian/tinypath/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dcsuibian/tinypath.git"
  },
  "license": "MIT",
  "author": "dcsuibian",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "format": "prettier --write src/",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "prettier": "3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
